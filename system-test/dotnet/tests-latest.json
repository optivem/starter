{
  "setupCommands": [
    { "name": "Clean", "command": "dotnet clean" },
    { "name": "Build", "command": "dotnet build" }
  ],
  "testFilter": "&DisplayName~<test>",
  "suites": [
    {
      "id": "smoke-stub",
      "name": "latest - Smoke (stub)",
      "command": "dotnet test --filter 'FullyQualifiedName~.Latest.SmokeTests' -e EXTERNAL_SYSTEM_MODE=stub --logger 'trx;LogFileName=testResults.trx' --logger 'html;LogFileName=testResults.html' --logger 'console;verbosity=detailed'",
      "path": "SystemTests",
      "testReportPath": "SystemTests\\TestResults\\testResults.html",
      "sampleTest": "ShouldBeAbleToGoToMyShop",
      "testInstallCommands": ["pwsh bin/Debug/net8.0/playwright.ps1 install"]
    },
    {
      "id": "smoke-real",
      "name": "latest - Smoke (real)",
