<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Optivem.Shop.Monolith</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Optivem.Shop.Monolith.styles.css" asp-append-version="true" />
    <style>
        .notification { padding: 12px; margin-top: 10px; margin-bottom: 16px; border-radius: 4px; font-weight: 600; }
        .notification.success { background: #d1e7dd; color: #0f5132; border: 1px solid #badbcc; }
        .notification.error { background: #f8d7da; color: #842029; border: 1px solid #f5c2c7; }
        .notification .error-message { margin-bottom: 8px; }
        .notification .field-error { margin-left: 12px; margin-top: 4px; font-weight: 400; }
        .status-PLACED { color: #198754; }
        body { min-height: 100vh; background-color: #f8f9fa; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="/">Shop</a>
            </div>
        </nav>
    </header>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Optivem.Shop.Monolith - <a href="/privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>