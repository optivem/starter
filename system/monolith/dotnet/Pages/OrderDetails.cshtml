@page "/order-details"
@model Optivem.Shop.Monolith.Pages.OrderDetailsModel
@{
    ViewData["Title"] = "Order Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/order-history">Order History</a></li>
        <li class="breadcrumb-item active" aria-current="page">Order Details</li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Order Details</h4>
    </div>
    <div class="card-body">
        <div id="loading" class="text-center py-5">
            <output>
                <div class="spinner-border text-primary">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </output>
            <p class="mt-3">Loading order details...</p>
        </div>

        <div id="orderDetails" style="display: none;">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <strong>Order Number:</strong>
                    <p id="detailOrderNumber" aria-label="Display Order Number"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Order Timestamp:</strong>
                    <p id="detailOrderTimestamp" aria-label="Display Order Timestamp"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Status:</strong>
                    <p id="detailStatus" aria-label="Display Status"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>SKU:</strong>
                    <p id="detailSku" aria-label="Display SKU"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Quantity:</strong>
                    <p id="detailQuantity" aria-label="Display Quantity"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Country:</strong>
                    <p id="detailCountry" aria-label="Display Country"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Unit Price:</strong>
                    <p id="detailUnitPrice" aria-label="Display Unit Price"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Base Price:</strong>
                    <p id="detailBasePrice" aria-label="Display Base Price"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Discount Rate:</strong>
                    <p id="detailDiscountRate" aria-label="Display Discount Rate"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Discount Amount:</strong>
                    <p id="detailDiscountAmount" aria-label="Display Discount Amount"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Subtotal Price:</strong>
                    <p id="detailSubtotalPrice" aria-label="Display Subtotal Price"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Tax Rate:</strong>
                    <p id="detailTaxRate" aria-label="Display Tax Rate"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Tax Amount:</strong>
                    <p id="detailTaxAmount" aria-label="Display Tax Amount"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Total Price:</strong>
                    <p id="detailTotalPrice" class="fs-5 fw-bold" aria-label="Display Total Price"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Applied Coupon Code:</strong>
                    <p id="detailAppliedCouponCode" aria-label="Display Applied Coupon"></p>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button id="cancelOrderBtn" class="btn btn-danger" aria-label="Cancel Order" onclick="cancelOrder()">Cancel Order</button>
                <button id="deliverOrderBtn" class="btn btn-warning" aria-label="Deliver Order" onclick="deliverOrder()">Deliver Order</button>
                <a href="/order-history" class="btn btn-secondary">Back to Order History</a>
            </div>
        </div>

        <div id="notifications"></div>

        <div id="errorMessage" style="display: none;"></div>

        <div id="notFound" style="display: none;" class="text-center py-5 text-muted">
            <p>Order not found</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function loadOrderDetails() {
        var params = new URLSearchParams(window.location.search);
        var orderNumber = params.get('orderNumber');
        var loading = document.getElementById('loading');
        var orderDetails = document.getElementById('orderDetails');
        var notFound = document.getElementById('notFound');
        var errorMessage = document.getElementById('errorMessage');

        if (!orderNumber) {
            loading.style.display = 'none';
            notFound.style.display = 'block';
            return;
        }

        try {
            var response = await fetch('/api/orders/' + encodeURIComponent(orderNumber));

            loading.style.display = 'none';

            if (response.status === 404) {
                notFound.style.display = 'block';
                return;
            }

            if (!response.ok) {
                var data = await response.json();
                errorMessage.innerHTML = '<div class="alert alert-danger d-flex justify-content-between align-items-center" role="alert"><div><strong>Error:</strong> ' + (data.detail || 'Failed to load order') + '</div></div>';
                errorMessage.style.display = 'block';
                return;
            }

            var order = await response.json();

            document.getElementById('detailOrderNumber').textContent = order.orderNumber;
            document.getElementById('detailOrderTimestamp').textContent = new Date(order.orderTimestamp).toLocaleString('en-US', { timeZone: 'UTC' });

            var statusEl = document.getElementById('detailStatus');
            statusEl.className = 'status-' + order.status;
            statusEl.textContent = order.status;

            document.getElementById('detailSku').textContent = order.sku;
            document.getElementById('detailQuantity').textContent = order.quantity;
            document.getElementById('detailCountry').textContent = order.country;
            document.getElementById('detailUnitPrice').textContent = '$' + order.unitPrice.toFixed(2);
            document.getElementById('detailBasePrice').textContent = '$' + order.basePrice.toFixed(2);
            document.getElementById('detailDiscountRate').textContent = (order.discountRate * 100).toFixed(2) + '%';
            document.getElementById('detailDiscountAmount').textContent = '$' + order.discountAmount.toFixed(2);
            document.getElementById('detailSubtotalPrice').textContent = '$' + order.subtotalPrice.toFixed(2);
            document.getElementById('detailTaxRate').textContent = (order.taxRate * 100).toFixed(2) + '%';
            document.getElementById('detailTaxAmount').textContent = '$' + order.taxAmount.toFixed(2);
            document.getElementById('detailTotalPrice').textContent = '$' + order.totalPrice.toFixed(2);
            document.getElementById('detailAppliedCouponCode').textContent = order.appliedCouponCode || '-';

            var isTerminal = order.status === 'CANCELLED' || order.status === 'DELIVERED';
            document.getElementById('cancelOrderBtn').style.display = isTerminal ? 'none' : '';
            document.getElementById('deliverOrderBtn').style.display = isTerminal ? 'none' : '';

            orderDetails.style.display = 'block';
        } catch (err) {
            loading.style.display = 'none';
            errorMessage.innerHTML = '<div class="alert alert-danger d-flex justify-content-between align-items-center" role="alert"><div><strong>Error:</strong> Network error: ' + err.message + '</div></div>';
            errorMessage.style.display = 'block';
        }
    }

    async function cancelOrder() {
        var params = new URLSearchParams(window.location.search);
        var orderNumber = params.get('orderNumber');
        if (!orderNumber) return;

        var notifications = document.getElementById('notifications');
        var btn = document.getElementById('cancelOrderBtn');

        window._notificationCounter = (window._notificationCounter || 0) + 1;
        var nid = window._notificationCounter;

        btn.disabled = true;
        btn.textContent = 'Cancelling...';
        notifications.innerHTML = '';

        try {
            var response = await fetch('/api/orders/' + encodeURIComponent(orderNumber) + '/cancel', { method: 'POST' });

            if (response.ok) {
                notifications.innerHTML = '<div class="notification success" role="alert" data-notification-id="' + nid + '">Order has been cancelled successfully</div>';
                loadOrderDetails();
            } else {
                var data = await response.json();
                var errorHtml = '<div class="notification error" role="alert" data-notification-id="' + nid + '">';
                errorHtml += '<div class="error-message">' + (data.detail || 'An error occurred') + '</div>';
                if (data.errors && data.errors.length > 0) {
                    data.errors.forEach(function(err) {
                        var fieldPart = err.field ? err.field + ': ' : '';
                        errorHtml += '<div class="field-error">' + fieldPart + err.message + '</div>';
                    });
                }
                errorHtml += '</div>';
                notifications.innerHTML = errorHtml;
            }
        } catch (err) {
            notifications.innerHTML = '<div class="notification error" role="alert" data-notification-id="' + nid + '"><div class="error-message">Network error: ' + err.message + '</div></div>';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Cancel Order';
        }
    }

    async function deliverOrder() {
        var params = new URLSearchParams(window.location.search);
        var orderNumber = params.get('orderNumber');
        if (!orderNumber) return;

        var notifications = document.getElementById('notifications');
        var btn = document.getElementById('deliverOrderBtn');

        window._notificationCounter = (window._notificationCounter || 0) + 1;
        var nid = window._notificationCounter;

        btn.disabled = true;
        btn.textContent = 'Delivering...';
        notifications.innerHTML = '';

        try {
            var response = await fetch('/api/orders/' + encodeURIComponent(orderNumber) + '/deliver', { method: 'POST' });

            if (response.ok) {
                notifications.innerHTML = '<div class="notification success" role="alert" data-notification-id="' + nid + '">Order has been delivered successfully</div>';
                loadOrderDetails();
            } else {
                var data = await response.json();
                var errorHtml = '<div class="notification error" role="alert" data-notification-id="' + nid + '">';
                errorHtml += '<div class="error-message">' + (data.detail || 'An error occurred') + '</div>';
                if (data.errors && data.errors.length > 0) {
                    data.errors.forEach(function(err) {
                        var fieldPart = err.field ? err.field + ': ' : '';
                        errorHtml += '<div class="field-error">' + fieldPart + err.message + '</div>';
                    });
                }
                errorHtml += '</div>';
                notifications.innerHTML = errorHtml;
            }
        } catch (err) {
            notifications.innerHTML = '<div class="notification error" role="alert" data-notification-id="' + nid + '"><div class="error-message">Network error: ' + err.message + '</div></div>';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Deliver Order';
        }
    }

    loadOrderDetails();
</script>
}
