@page "/order-details"
@model Optivem.Starter.Monolith.Pages.OrderDetailsModel
@{
    ViewData["Title"] = "Order Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/order-history">Order History</a></li>
        <li class="breadcrumb-item active" aria-current="page">Order Details</li>
    </ol>
</nav>

<div id="notification"></div>

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Order Details</h4>
    </div>
    <div class="card-body">
        <div id="loading" class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading order details...</p>
        </div>

        <div id="orderDetails" style="display: none;">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Order Number</label>
                    <p id="detailOrderNumber" aria-label="Display Order Number"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Order Timestamp</label>
                    <p id="detailOrderTimestamp" aria-label="Display Order Timestamp"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Status</label>
                    <p id="detailStatus" aria-label="Display Status"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">SKU</label>
                    <p id="detailSku" aria-label="Display SKU"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Quantity</label>
                    <p id="detailQuantity" aria-label="Display Quantity"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Unit Price</label>
                    <p id="detailUnitPrice" aria-label="Display Unit Price"></p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Total Price</label>
                    <p id="detailTotalPrice" class="fs-5 fw-bold" aria-label="Display Total Price"></p>
                </div>
            </div>

            <div class="mt-4">
                <a href="/order-history" class="btn btn-secondary">Back to Order History</a>
            </div>
        </div>

        <div id="notFound" style="display: none;" class="text-center text-muted">
            <p>Order not found</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function loadOrderDetails() {
        const params = new URLSearchParams(window.location.search);
        const orderNumber = params.get('orderNumber');
        const loading = document.getElementById('loading');
        const orderDetails = document.getElementById('orderDetails');
        const notFound = document.getElementById('notFound');
        const notification = document.getElementById('notification');

        if (!orderNumber) {
            loading.style.display = 'none';
            notFound.style.display = 'block';
            return;
        }

        try {
            const response = await fetch('/api/orders/' + encodeURIComponent(orderNumber));

            loading.style.display = 'none';

            if (response.status === 404) {
                notFound.style.display = 'block';
                return;
            }

            if (!response.ok) {
                const data = await response.json();
                notification.innerHTML = '<div class="alert alert-danger" role="alert">' + (data.detail || 'Failed to load order') + '</div>';
                return;
            }

            const order = await response.json();

            document.getElementById('detailOrderNumber').textContent = order.orderNumber;
            document.getElementById('detailOrderTimestamp').textContent = new Date(order.orderTimestamp).toLocaleString('en-US', { timeZone: 'UTC' });
            document.getElementById('detailStatus').innerHTML = '<span class="badge bg-success">' + order.status + '</span>';
            document.getElementById('detailSku').textContent = order.sku;
            document.getElementById('detailQuantity').textContent = order.quantity;
            document.getElementById('detailUnitPrice').textContent = '$' + order.unitPrice.toFixed(2);
            document.getElementById('detailTotalPrice').textContent = '$' + order.totalPrice.toFixed(2);

            orderDetails.style.display = 'block';
        } catch (err) {
            loading.style.display = 'none';
            notification.innerHTML = '<div class="alert alert-danger" role="alert">Network error: ' + err.message + '</div>';
        }
    }

    loadOrderDetails();
</script>
}
